# Google Analytics tag ID (optional)
NUXT_PUBLIC_GTAG_ID=

# Secret shared with Payload CMS to authenticate preview requests
# Must match PREVIEW_SECRET in cms/.env
PREVIEW_SECRET=change-this-to-a-random-string

# Internal URL of the Payload CMS service (used server-side only)
PAYLOAD_URL=http://cms:3001

# Public URL of the Payload CMS service (used in the browser for live preview and media)
NUXT_PUBLIC_PAYLOAD_URL=http://localhost:4101

# Payload CMS API key for fetching draft posts during preview
# Generate this from a User record in the Payload admin panel
PAYLOAD_API_KEY=
