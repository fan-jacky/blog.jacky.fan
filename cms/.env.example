# Required: A long random string used to sign JWTs
PAYLOAD_SECRET=change-this-to-a-long-random-string

# MongoDB connection URI
DATABASE_URI=mongodb://mongodb:27017/blog-cms

# Public URL of the CMS server (used for admin panel links and CORS)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Public URL of the Nuxt blog (used for preview links and CORS)
PAYLOAD_PUBLIC_SITE_URL=http://localhost:3000

# Secret shared with the Nuxt blog to authenticate preview requests
PREVIEW_SECRET=change-this-to-another-random-string

# Port the CMS server listens on
PORT=3001
