{
  "name": "blog-cms",
  "version": "1.0.0",
  "description": "Payload CMS for blog.jacky.fan",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "postinstall": "npm rebuild sharp && cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack -p 4101",
    "prebuild": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 4101",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:graphql": "payload generate:graphql"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-slate": "^3.85.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "graphql": "^16.12.0",
    "next": "^16.2.6",
    "payload": "^3.85.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "sass": "^1.100.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
