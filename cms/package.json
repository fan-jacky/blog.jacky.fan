{
  "name": "blog-cms",
  "version": "1.0.0",
  "description": "Payload CMS for blog.jacky.fan",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --exec ts-node --project tsconfig.json src/server.ts",
    "build": "payload build && tsc",
    "start": "cross-env PAYLOAD_CONFIG_PATH=dist/payload.config.js node dist/server.js",
    "generate:types": "payload generate:types",
    "generate:graphql": "payload generate:graphql"
  },
  "dependencies": {
    "@payloadcms/bundler-webpack": "^1.0.9",
    "@payloadcms/db-mongodb": "^1.4.3",
    "@payloadcms/richtext-slate": "^1.5.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "payload": "^2.31.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
